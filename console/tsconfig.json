{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "allowUnreachableCode": false,
    "incremental": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "noEmit": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "paths": {
      "~/*": ["./app/*"]
    },
    "skipLibCheck": true,
    "target": "es2023",
    "types": ["node", "vite/client", "vitest/importMeta"]
  },
  "exclude": ["app/api/__generated__"]
}
